#!/usr/bin/env -S nvim -l

local storage = vim.fn.stdpath("data") .. "/ethereal-annotations"

local function hash(path)
  if vim.fn.filereadable(path) == 0 then return nil end
  return vim.fn.sha256(table.concat(vim.fn.readfile(path), "\n"))
end

local function parse(path)
  if vim.fn.filereadable(path) == 0 then return nil, {} end
  local lines = vim.fn.readfile(path)
  if #lines == 0 then return nil, {} end

  local source, annotations = lines[1], {}
  for i = 2, #lines do
    local range, comment = lines[i]:match("^([^:]+):(.*)$")
    if range then
      local s, e = range:match("^(%d+)-(%d+)$")
      if not s then s, e = range:match("^(%d+)$"), range:match("^(%d+)$") end
      if s then table.insert(annotations, { s = tonumber(s), e = tonumber(e), comment = comment }) end
    end
  end
  return source, annotations
end

local function list(filter)
  if vim.fn.isdirectory(storage) == 0 then print("No annotations found") return end

  local found = false
  for _, f in ipairs(vim.fn.glob(storage .. "/*.txt", false, true)) do
    local source, annotations = parse(f)
    if source and #annotations > 0 then
      if not filter or source == filter or vim.fn.fnamemodify(source, ":t") == filter then
        local h = hash(source)
        if h and h == vim.fn.fnamemodify(f, ":t:r") then
          for _, a in ipairs(annotations) do
            found = true
            local range = a.s == a.e and tostring(a.s) or (a.s .. "-" .. a.e)
            print(string.format("%s:%s: %s", source, range, a.comment))
          end
        else
          vim.fn.delete(f)
        end
      end
    end
  end
  if not found then print("No annotations found") end
end

local function clear(file, all)
  if all then
    if vim.fn.isdirectory(storage) == 1 then
      for _, f in ipairs(vim.fn.glob(storage .. "/*.txt", false, true)) do vim.fn.delete(f) end
    end
    print("Cleared all annotations")
    return
  end

  if not file then print("Error: --file or --all required") os.exit(1) end

  local path = vim.fn.fnamemodify(file, ":p")
  local h = hash(path)
  if h then
    local f = storage .. "/" .. h .. ".txt"
    if vim.fn.filereadable(f) == 1 then
      vim.fn.delete(f)
      print("Cleared: " .. path)
      return
    end
  end

  if vim.fn.isdirectory(storage) == 1 then
    for _, f in ipairs(vim.fn.glob(storage .. "/*.txt", false, true)) do
      local source = parse(f)
      if source and vim.fn.fnamemodify(source, ":t") == file then
        vim.fn.delete(f)
        print("Cleared: " .. source)
        return
      end
    end
  end
  print("No annotations found for " .. file)
end

local function help()
  print([[
ethereal - Ephemeral code annotations for AI

Usage:
  ethereal list [--file <path>]
  ethereal clear --file <path>
  ethereal clear --all]])
end

local cmd, file, all
for i, a in ipairs(arg or {}) do
  if a == "list" or a == "clear" or a == "help" then cmd = a
  elseif a == "--file" then file = arg[i + 1]
  elseif a == "--all" then all = true end
end

if cmd == "list" then list(file)
elseif cmd == "clear" then clear(file, all)
else help() end
